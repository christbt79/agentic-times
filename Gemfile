source "https://rubygems.org"

# Match GitHub Pages' Jekyll for local development.
# GitHub Pages builds with Jekyll 3.9.x, so we pin to that for parity.
gem "jekyll", "~> 3.9"

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
end

# GitHub Pages renders posts as GitHub-Flavored Markdown.
gem "kramdown-parser-gfm"

# Pin native deps to versions compatible with the system Ruby 2.6.
gem "ffi", "~> 1.15.5"
